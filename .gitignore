# =============================================================================
# EROS Schedule Generator - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# macOS System Files
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store
._*

# -----------------------------------------------------------------------------
# Python Cache & Compiled Files
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# LLM Protocol Temporary Files
# -----------------------------------------------------------------------------
scripts/.llm_request.json
scripts/.llm_response.json
.llm_request.json
.llm_response.json

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Environment & Configuration
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.local.json
settings.local.json

# -----------------------------------------------------------------------------
# Logs & Debugging
# -----------------------------------------------------------------------------
*.log
logs/
debug/

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Archive (if created for cleanup)
# -----------------------------------------------------------------------------
archive/
