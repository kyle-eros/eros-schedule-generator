# EROS Schedule Generator - Environment Variables
# Copy this file to .env and customize with your actual paths

# ============================================================================
# REQUIRED: Database Configuration
# ============================================================================

# Path to the EROS SQLite database (REQUIRED)
# Contains creator profiles, caption bank, historical performance data
EROS_DATABASE_PATH=/path/to/EROS-SD-MAIN-PROJECT/database/eros_sd_main.db

# ============================================================================
# OPTIONAL: Path Configuration
# ============================================================================

# Project root directory (optional, used for relative path resolution)
EROS_PROJECT_PATH=/path/to/EROS-SD-MAIN-PROJECT

# Default output directory for generated schedules (optional)
# Default: ~/Developer/EROS-SD-MAIN-PROJECT/schedules
# EROS_SCHEDULES_PATH=/path/to/schedules/output

# ============================================================================
# OPTIONAL: Business Rules Overrides
# ============================================================================

# Minimum spacing between PPV messages in hours
# Default: 4 (ERROR if < 3, WARNING if < 4)
# EROS_PPV_MIN_SPACING_HOURS=4

# Maximum PPV messages per day
# Default: 6 (varies by volume level)
# EROS_PPV_MAX_PER_DAY=6

# Minimum freshness score required for scheduling
# Default: 30.0 (ERROR if < 25, WARNING if < 30)
# EROS_FRESHNESS_MINIMUM_SCORE=30.0

# Freshness half-life in days (exponential decay)
# Default: 14.0
# EROS_FRESHNESS_HALF_LIFE_DAYS=14.0

# ============================================================================
# OPTIONAL: Feature Flags
# ============================================================================

# Enable follow-up bump messages after PPVs
# Default: false
# EROS_ENABLE_FOLLOW_UPS=true

# Enable drip window enforcement (no-PPV zones)
# Default: false
# EROS_ENABLE_DRIP_WINDOWS=true

# Enable page type rules (paid vs free adjustments)
# Default: false
# EROS_ENABLE_PAGE_TYPE_RULES=true

# ============================================================================
# OPTIONAL: Performance Tuning
# ============================================================================

# Timing variance range in minutes (for organic scheduling)
# Default: -10 to +10 minutes, applied to 85% of slots
# EROS_TIMING_VARIANCE_MIN=-10
# EROS_TIMING_VARIANCE_MAX=10

# Probability of applying timing variance to a slot
# Default: 0.85 (85% of slots get variance)
# EROS_VARIANCE_PROBABILITY=0.85

# ============================================================================
# OPTIONAL: Weight Calculation Overrides
# ============================================================================

# Weight component percentages (must sum to 1.0)
# Default: Earnings(0.60) + Freshness(0.15) + Persona(0.15) + Discovery(0.10)

# EROS_WEIGHT_EARNINGS_PCT=0.60
# EROS_WEIGHT_FRESHNESS_PCT=0.15
# EROS_WEIGHT_PERSONA_PCT=0.15
# EROS_WEIGHT_DISCOVERY_PCT=0.10

# ============================================================================
# OPTIONAL: Hook Rotation Settings
# ============================================================================

# Penalty multiplier for consecutive same hook types (anti-detection)
# Default: 0.70 (30% penalty)
# EROS_SAME_HOOK_PENALTY=0.70

# Minimum hook types per week for diversity
# Default: 4
# EROS_MIN_HOOK_DIVERSITY=4

# ============================================================================
# OPTIONAL: Pool Selection Settings
# ============================================================================

# Minimum creator usage count for PROVEN pool
# Default: 3
# EROS_PROVEN_MIN_USES=3

# Minimum global usage count for GLOBAL_EARNER pool
# Default: 3
# EROS_GLOBAL_MIN_USES=3

# Discount factor for GLOBAL_EARNER pool earnings
# Default: 0.80 (20% discount vs creator-specific)
# EROS_GLOBAL_DISCOUNT=0.80

# ============================================================================
# OPTIONAL: Validation Settings
# ============================================================================

# Maximum auto-correction passes during validation
# Default: 2
# EROS_MAX_VALIDATION_PASSES=2

# Enable strict mode (treat warnings as errors)
# Default: false
# EROS_STRICT_VALIDATION=false

# ============================================================================
# OPTIONAL: Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# EROS_LOG_LEVEL=INFO

# Log file path (optional, defaults to console only)
# EROS_LOG_FILE=/path/to/logs/eros_schedule_generator.log

# ============================================================================
# Example Production Configuration
# ============================================================================

# EROS_DATABASE_PATH=/Users/kylemerriman/Developer/EROS-SD-MAIN-PROJECT/database/eros_sd_main.db
# EROS_PROJECT_PATH=/Users/kylemerriman/Developer/EROS-SD-MAIN-PROJECT
# EROS_PPV_MIN_SPACING_HOURS=4
# EROS_FRESHNESS_MINIMUM_SCORE=30.0
# EROS_ENABLE_FOLLOW_UPS=true
# EROS_LOG_LEVEL=INFO
